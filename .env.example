# paper|live|both
# Use paper if you want IB Gateway to log into the simulated trading session.
# Use live if you want the live session.
# Use both only if you intentionally want both sessions inside one container.
TRADING_MODE=paper

# yes|no
# if yes no trades can be placed
READ_ONLY_API=yes

# Paper trading credentials.
# Required when TRADING_MODE=paper or TRADING_MODE=both.
TWS_USERID_PAPER=your_ibkr_paper_username
TWS_PASSWORD_PAPER=your_ibkr_paper_password

# Live trading credentials.
# Required when TRADING_MODE=live or TRADING_MODE=both.
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# accept|reject|manual
TWS_ACCEPT_INCOMING=accept

# restart|exit
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes

# Optional VNC password for GUI troubleshooting.
# Leave blank to disable the VNC server.
VNC_SERVER_PASSWORD=change_me

# Time zone in tz database format
TIME_ZONE=Etc/UTC

# Optional daily restart handled by IBC
AUTO_RESTART_TIME=11:59 PM

# Host binding for the exposed API sockets. Keep 127.0.0.1 unless you add your own network security layer.
IB_GATEWAY_BIND_ADDRESS=127.0.0.1

# Host ports that frontends or backend services connect to.
# Connect your app to 4002 for paper or 4001 for live.
IB_GATEWAY_LIVE_HOST_PORT=4001
IB_GATEWAY_PAPER_HOST_PORT=4002
IB_GATEWAY_VNC_HOST_PORT=5900
